.hero {
  position: relative;
  overflow: hidden;
}

.hero-content {
  text-align: center;
}

.hero::before {
  z-index: 0;
}

.hero h1 {
  color: white;
  font-size: clamp(3rem, 6vw, 6rem);
  font-weight: 800;
  line-height: 1.05;
}

.hero p {
  color: rgba(255,255,255,0.8);
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

